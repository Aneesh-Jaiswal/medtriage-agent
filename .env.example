# Copy this file to .env and fill in your keys.
# Only OpenAI is wired up by default (used for LLM calls + embeddings in
# rag/retriever.py and the LangChain agents). Swap for Anthropic/other
# providers if preferred -- just update the model imports accordingly.

OPENAI_API_KEY=your_openai_api_key_here

# Optional: enable LangSmith tracing for observability into the LangGraph run
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_api_key_here
# LANGCHAIN_PROJECT=medtriage-agent
